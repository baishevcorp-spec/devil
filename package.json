{
  "name": "devil",
  "version": "0.1.0",
  "description": "Интеллектуальный агент-ассистент для VS Code с долговременной памятью, графовой БД и интеграцией с LLM.",
  "main": "./out/extension.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "test": "jest",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "lint:fix": "eslint src --ext ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "pretest": "npm run compile",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "ai",
    "assistant",
    "llm",
    "code generation",
    "memory"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.43",
    "@types/sql.js": "^1.4.11",
    "@types/vscode": "^1.125.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vscode/vsce": "^2.32.0",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "prettier": "^3.8.4",
    "ts-jest": "^29.4.11",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "axios": "^1.18.1",
    "flexsearch": "^0.8.212",
    "highlight.js": "^11.11.1",
    "keytar": "^7.9.0",
    "marked": "^18.0.5",
    "sql.js": "^1.14.1"
  },
  "engines": {
    "vscode": "^1.125.0"
  },
  "displayName": "Devil — AI Assistant for Developers",
  "publisher": "baish",
  "categories": [
    "Machine Learning",
    "Programming Languages",
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/baish/devil"
  },
  "activationEvents": [
    "onCommand:devil.hello",
    "onCommand:devil.openChat",
    "onCommand:devil.openProject"
  ],
  "contributes": {
    "commands": [
      {
        "command": "devil.hello",
        "title": "Devil: Hello (тестовая команда)",
        "category": "Devil"
      },
      {
        "command": "devil.openChat",
        "title": "Devil: Open Chat",
        "category": "Devil"
      },
      {
        "command": "devil.openProject",
        "title": "Devil: Open Project",
        "category": "Devil"
      },
      {
        "command": "devil.explainSelection",
        "title": "Объяснить код с Devil",
        "category": "Devil"
      }
    ],
    "configuration": {
      "title": "Devil",
      "properties": {
        "devil.baseUrl": {
          "type": "string",
          "default": "http://localhost:11434/v1",
          "description": "Base URL для LLM API (OpenAI-совместимый). Примеры: https://api.openai.com/v1, https://api.myproxyapi.ru/v1, http://localhost:11434/v1 (для Ollama)"
        },
        "devil.apiKey": {
          "type": "string",
          "default": "",
          "description": "API-ключ для LLM. Хранится в settings.json (в будущем — в keytar)."
        },
        "devil.model": {
          "type": "string",
          "default": "llama3",
          "description": "Модель LLM по умолчанию. Примеры: gpt-4o, gpt-4o-mini, claude-3-5-sonnet, llama3"
        },
        "devil.maxRetries": {
          "type": "number",
          "default": 3,
          "minimum": 0,
          "maximum": 10,
          "description": "Количество повторных попыток при ошибке сети/LLM."
        },
        "devil.cacheTtlSeconds": {
          "type": "number",
          "default": 604800,
          "minimum": 0,
          "description": "Время жизни кэша ответов LLM в секундах. По умолчанию 7 дней (604800)."
        },
        "devil.defaultSystemPrompt": {
          "type": "string",
          "default": "Ты — Devil, интеллектуальный ассистент для разработчика. Отвечай на русском языке, кратко и по делу. Используй Markdown для форматирования.",
          "description": "Системный промпт по умолчанию для всех запросов к LLM."
        },
        "devil.debugMode": {
          "type": "boolean",
          "default": false,
          "description": "Включить DEBUG-логи в Output Channel \"Devil\"."
        }
      }
    },
    "menus": {
      "editor/context": [
        {
          "command": "devil.explainSelection",
          "when": "editorHasSelection",
          "group": "devil@1"
        }
      ]
    }
  }
}
