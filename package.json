{
  "name": "devil",
  "version": "0.1.0",
  "description": "Интеллектуальный агент-ассистент для VS Code с долговременной памятью, графовой БД и интеграцией с LLM.",
  "main": "./out/extension.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "test": "jest",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "lint:fix": "eslint src --ext ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "pretest": "npm run compile",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "ai",
    "assistant",
    "llm",
    "code generation",
    "memory"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.43",
    "@types/vscode": "^1.125.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vscode/vsce": "^2.32.0",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "prettier": "^3.8.4",
    "ts-jest": "^29.4.11",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "axios": "^1.18.1"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "displayName": "Devil — AI Assistant for Developers",
  "publisher": "baish",
  "categories": [
    "Machine Learning",
    "Programming Languages",
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/baish/devil"
  },
  "activationEvents": [
    "onCommand:devil.hello",
    "onCommand:devil.openChat",
    "onCommand:devil.openProject"
  ],
  "contributes": {
    "commands": [
      {
        "command": "devil.hello",
        "title": "Devil: Hello (тестовая команда)",
        "category": "Devil"
      },
      {
        "command": "devil.openChat",
        "title": "Devil: Open Chat",
        "category": "Devil"
      },
      {
        "command": "devil.openProject",
        "title": "Devil: Open Project",
        "category": "Devil"
      }
    ],
    "configuration": {
      "title": "Devil",
      "properties": {
        "devil.baseUrl": {
          "type": "string",
          "default": "https://api.myproxyapi.ru/v1",
          "description": "Base URL для LLM API (OpenAI-совместимый)"
        },
        "devil.apiKey": {
          "type": "string",
          "default": "",
          "description": "API ключ для LLM (хранится в настройках VS Code)"
        },
        "devil.model": {
          "type": "string",
          "default": "gpt-4o-mini",
          "description": "Модель LLM по умолчанию"
        }
      }
    }
  }
}
